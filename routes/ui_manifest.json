    {
      "intent": "settings",
      "description": "MAX / mat-gram model lifecycle: start serve and connect weights",
      "endpoints": [
        {
          "id": "start_max",
          "intent": "settings_start_max",
          "description": "Start the local MAX serve process with default pretrained SMI-TED weights",
          "view_kind": "panel",
          "label": "Start MAX",
          "icon": "play",
          "url": "http://127.0.0.1:8011/settings/start-max",
          "method": "post",
          "port": 8011,
          "path": "/settings/start-max",
          "form": [
            {
              "name": "device",
              "kind": "select",
              "label": "Device",
              "default": "cpu",
              "options": [
                "cpu",
                "gpu"
              ]
            }
          ]
        },
        {
          "id": "load_weights",
          "intent": "settings_load_weights",
          "description": "Connect a weight_path or finetune checkpoint (esol/bbbp/lipo) to MAX",
          "view_kind": "panel",
          "label": "Weights",
          "icon": "hard-drive",
          "url": "http://127.0.0.1:8011/settings/load-weights",
          "method": "post",
          "port": 8011,
          "path": "/settings/load-weights",
          "form": [
            {
              "name": "task",
              "kind": "select",
              "label": "Weights / task",
              "default": "pretrained",
              "options": [
                "pretrained",
                "esol",
                "bbbp",
                "lipo"
              ]
            },
            {
              "name": "weight_path",
              "kind": "text",
              "label": "weight_path (optional)",
              "default": "./model_assets/ibm-research_materials.smi-ted",
              "options": []
            },
            {
              "name": "checkpoint",
              "kind": "text",
              "label": "checkpoint (optional)",
              "default": "",
              "options": []
            },
            {
              "name": "device",
              "kind": "select",
              "label": "Device",
              "default": "cpu",
              "options": [
                "cpu",
                "gpu"
              ]
            }
          ]
        },
        {
          "id": "stop_max",
          "intent": "settings_stop_max",
          "description": "Stop the local MAX serve subprocess",
          "view_kind": "panel",
          "label": "Stop MAX",
          "icon": "square",
          "url": "http://127.0.0.1:8011/settings/stop-max",
          "method": "post",
          "port": 8011,
          "path": "/settings/stop-max",
          "form": []
        }
      ]
