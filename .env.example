# Railway UI service — backends stay on this Hetzner host.
# Public hostname used in routes/router_graph.json:
#   static.29.136.62.46.clients.your-server.de

JWT_AUTH_DISABLED=true
JWT_DEV_USER=dev@local
JWT_DEV_ROLES=admin,analyst

# AGE Postgres on this server (URL-encode special chars in the password)
ROUTER_DATABASE_URL=postgresql://postgres:CHANGE_ME@static.29.136.62.46.clients.your-server.de:5432/string_therapy

# Lisette / LiteLLM (required for chat routing)
LISETTE_MODEL=gemini/gemini-3.5-flash
LISETTE_API_KEY=

# Optional: mat-gram base if anything in this process calls it directly
MATGRAM_API_URL=http://static.29.136.62.46.clients.your-server.de:8080

# Analysts / batch on this host (not Railway) — bind with:
#   ANALYST_HOST=0.0.0.0 BATCH_HOST=0.0.0.0
