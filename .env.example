# App + controller run on this Hetzner host (not on Railway).
# Railway is only a Caddy reverse proxy — set UPSTREAM there to this host:4546.

JWT_AUTH_DISABLED=true
JWT_DEV_USER=dev@local
JWT_DEV_ROLES=admin,analyst

# Local AGE on this server
ROUTER_DATABASE_URL=postgresql://postgres:CHANGE_ME@127.0.0.1:5432/string_therapy

LISETTE_MODEL=gemini/gemini-3.5-flash
LISETTE_API_KEY=

# Local mat-gram (controller/batch on this host)
MATGRAM_API_URL=http://127.0.0.1:8080

# UI listen port (public for Railway proxy)
PORT=4546
UVICORN_RELOAD=0

# Railway proxy service only:
#   UPSTREAM=http://static.29.136.62.46.clients.your-server.de:4546
